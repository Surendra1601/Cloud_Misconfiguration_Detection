{
  "remediation_id": "REM_02",
  "title": "Enforce IAM Password Policy",
  "domain": "identity_access",
  "severity": "high",
  "check_id": "CHECK_02",
  "console_steps": [
    "1. Open the IAM console",
    "2. Click 'Account settings' in the left nav",
    "3. Under Password policy, click 'Edit'",
    "4. Set minimum length to 14 characters",
    "5. Require uppercase, lowercase, numbers, symbols",
    "6. Enable password expiration (90 days)",
    "7. Prevent password reuse (24 passwords)",
    "8. Click 'Save changes'"
  ],
  "cli_command": "aws iam update-account-password-policy --minimum-password-length 14 --require-symbols --require-numbers --require-uppercase-characters --require-lowercase-characters --max-password-age 90 --password-reuse-prevention 24",
  "cli_example": "aws iam update-account-password-policy --minimum-password-length 14 --require-symbols --require-numbers --require-uppercase-characters --require-lowercase-characters --max-password-age 90 --password-reuse-prevention 24",
  "terraform_snippet": "resource \"aws_iam_account_password_policy\" \"strict\" {\n  minimum_password_length        = 14\n  require_lowercase_characters   = true\n  require_uppercase_characters   = true\n  require_numbers                = true\n  require_symbols                = true\n  max_password_age               = 90\n  password_reuse_prevention      = 24\n  allow_users_to_change_password = true\n}",
  "references": [
    {
      "framework": "CIS AWS Foundations Benchmark",
      "control_id": "1.8",
      "title": "Ensure IAM password policy requires minimum length of 14"
    },
    {
      "framework": "NIST 800-53",
      "control_id": "IA-5",
      "title": "Authenticator Management"
    },
    {
      "framework": "PCI DSS",
      "control_id": "8.2.3",
      "title": "Passwords must meet complexity requirements"
    }
  ],
  "estimated_fix_time_minutes": 5,
  "risk_reduction": "High — enforces strong credential standards",
  "rollback_difficulty": "Easy — policy can be reverted"
}
