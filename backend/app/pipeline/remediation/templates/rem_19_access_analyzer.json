{
  "remediation_id": "REM_19",
  "title": "Enable IAM Access Analyzer",
  "domain": "identity_access",
  "severity": "medium",
  "check_id": "CHECK_19",
  "console_steps": [
    "1. Open the IAM console",
    "2. Click 'Access Analyzer' in the left nav",
    "3. Click 'Create analyzer'",
    "4. Select 'Account' as the zone of trust",
    "5. Give the analyzer a name",
    "6. Click 'Create analyzer'",
    "7. Review findings and resolve external access"
  ],
  "cli_command": "aws accessanalyzer create-analyzer --analyzer-name {ANALYZER_NAME} --type ACCOUNT",
  "cli_example": "aws accessanalyzer create-analyzer --analyzer-name account-analyzer --type ACCOUNT",
  "terraform_snippet": "resource \"aws_accessanalyzer_analyzer\" \"account\" {\n  analyzer_name = \"account-analyzer\"\n  type          = \"ACCOUNT\"\n\n  tags = {\n    Environment = \"production\"\n  }\n}",
  "references": [
    {
      "framework": "CIS AWS Foundations Benchmark",
      "control_id": "1.20",
      "title": "Ensure IAM Access Analyzer is enabled"
    },
    {
      "framework": "NIST 800-53",
      "control_id": "AC-6",
      "title": "Least Privilege"
    },
    {
      "framework": "SOC 2",
      "control_id": "CC6.1",
      "title": "Logical access controls"
    }
  ],
  "estimated_fix_time_minutes": 5,
  "risk_reduction": "Medium — identifies unintended external resource access",
  "rollback_difficulty": "Easy — analyzer can be deleted"
}
